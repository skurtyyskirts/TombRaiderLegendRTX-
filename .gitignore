tools/radare2-5*/
tools/apitrace-*/

# Autopatch diagnostic captures (large JSONL frame data, regenerated per run)
autopatch/diagnostic_captures/*.jsonl

# Large JSONL trace captures (regenerated per capture session)
TRL traces/**/*.jsonl

# Runtime proxy/tracer logs in test builds and traces
TRL tests/**/ffp_proxy.log
# Keep the build-071 fixture log — it is a test fixture for test_proxy_log_parsing.py
!TRL tests/build-071-hash-stability-FAIL-lights-missing/ffp_proxy.log
