# Research artifacts
compass_artifact_*

# Agent memory (machine-specific, regenerated per session)
.claude/agent-memory/

# Superpowers specs/plans (session artifacts)
docs/

# Game directory (23GB game assets — not source)
/Tomb Raider Legend/

# Nested repo clones (not submodules)
/TombRaiderLegendRTX-/
/TRLAU-menu-hook/
/TombRaiderLegend/
/TR7SCU/

# Tool archives (downloaded, not source)
tools/apitrace-*.7z
